<Window x:Class="Widgicity.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Widgicity Settings" Width="420" Height="320"
        Background="#121214" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Application Settings" Foreground="#EAEAEA" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <CheckBox x:Name="ChkLaunchAtStartup" Content="Launch Widgicity when Windows starts"
                  Foreground="#EAEAEA" Margin="0,0,0,15"/>

        <CheckBox x:Name="ChkStartMinimized" Content="Start minimized to the system tray"
                  Foreground="#EAEAEA" Margin="0,0,0,15"/>

        <TextBlock Text="Process-check interval (seconds), used by widgets that only show when a game/app is running:"
                   Foreground="#EAEAEA" TextWrapping="Wrap" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtPollInterval" Width="60" HorizontalAlignment="Left" Height="26"
             Background="#2D2D35" Foreground="White" BorderThickness="0"
             HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
             VerticalAlignment="Center" Margin="0,0,0,25"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Width="90" Height="32" Margin="0,0,10,0"
                    Background="#2D2D35" Foreground="White" BorderThickness="0"/>
            <Button Content="Save" Click="Save_Click" Width="90" Height="32"
                    Background="#6200EE" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </StackPanel>
</Window>