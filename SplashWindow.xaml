<Window x:Class="Widgicity.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True"
        Width="420" Height="110" ResizeMode="NoResize">
    <Border Background="#1E1E24" CornerRadius="10" BorderBrush="#6200EE" BorderThickness="1">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
            <TextBlock Text="Widgicity" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TxtStatus" Text="Starting up…" Foreground="#9E9E9E" FontSize="12"
                       Margin="0,6,0,0" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap" MaxWidth="380"/>
        </StackPanel>
    </Border>
</Window>