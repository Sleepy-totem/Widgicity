<Window x:Class="Widgicity.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick a Running App" Width="420" Height="480"
        Background="#121214" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="15">
        <TextBlock DockPanel.Dock="Top" Text="Select the app/game this widget should only show for:"
                   Foreground="#EAEAEA" TextWrapping="Wrap" Margin="0,0,0,10"/>
        <Button DockPanel.Dock="Bottom" Content="Cancel" Click="Cancel_Click" Height="32" Margin="0,10,0,0"
                Background="#2D2D35" Foreground="White" BorderThickness="0"/>
        <ListBox x:Name="AppsListBox" Background="#1E1E24" BorderThickness="0"
                 MouseDoubleClick="AppsListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayTitle}" Foreground="#EAEAEA" Padding="4"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>